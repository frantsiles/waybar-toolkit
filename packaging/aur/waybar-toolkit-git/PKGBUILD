pkgname=waybar-toolkit-git
pkgver=r1.g0000000
pkgrel=1
pkgdesc="Wayland utility hub with Waybar integration (monitor + process tools) - git version"
arch=('any')
url="https://github.com/frantsiles/waybar-toolkit"
license=('MIT')
depends=('python' 'python-gobject' 'gtk4')
makedepends=('git' 'python-build' 'python-installer' 'python-setuptools' 'python-wheel')
optdepends=(
  'brightnessctl: laptop backlight brightness control'
  'ddcutil: external monitor brightness/contrast via DDC/CI'
)
provides=('waybar-toolkit')
conflicts=('waybar-toolkit')
source=('git+https://github.com/frantsiles/waybar-toolkit.git')
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/waybar-toolkit"
  printf "r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/waybar-toolkit"
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/waybar-toolkit"
  python -m installer --destdir="$pkgdir" dist/*.whl
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
